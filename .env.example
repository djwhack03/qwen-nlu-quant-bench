# ============================================================
# qwen-nlu-quant-bench — environment configuration
# ============================================================
# Copy this file to .env and adjust paths for your machine.
# If not set, all paths default to subdirectories of the repo root.
#
# Windows example:
#   QUANT_BASE_DIR=E:/quant
#
# Linux/Mac example:
#   QUANT_BASE_DIR=/home/user/quant
# ============================================================

# Root directory for all models, data and outputs.
# Leave unset to use the repo root.
# QUANT_BASE_DIR=

# Override individual paths if needed (all optional).
# DATASET_NER_PATH=
# DATASET_SA_PATH=
# OUTPUT_DIR=
# BASE_MODEL_PATH=
